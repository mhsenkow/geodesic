{
  "name": "geodesic",
  "version": "1.2.0",
  "description": "Generate organic, 3D-printable geodesic dome connector hubs",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "npm run test:unit && npm run test:e2e && npm run test:visual",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test:visual": "playwright test tests/visual",
    "test:visual:update": "playwright test tests/visual --update-snapshots"
  },
  "dependencies": {
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.50.0",
    "@types/three": "^0.160.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
